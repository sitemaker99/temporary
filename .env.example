# ── Aniflix + Anveshna Streaming Config ─────────────────────────────────────

# Primary Consumet/Anilist backend (for home, search, trending data)
# Example: https://api.consumet.org/
NEXT_PUBLIC_BACKEND_URL=""

# CF (Cloudflare-proxied) backend for streaming sources & servers
# Example: https://api.anveshna.com/ or your own CF Workers deployment
NEXT_PUBLIC_CF_BACKEND_URL=""

# Streaming backend URL (HiAnime/HiAnime-compatible)
# Example: https://stream.anveshna.com/
NEXT_PUBLIC_STREAMING_BACKEND_URL=""

# Cloudflare media proxy for fetching .m3u8 streams without CORS issues
# Example: https://cf-proxy.anveshna.com/
NEXT_PUBLIC_CF_PROXY_URL=""

# (Optional) Skip times API - aniskip.com compatible
# Example: https://api.aniskip.com/
NEXT_PUBLIC_SKIP_TIMES=""

# (Optional) CORS proxy for external requests
# Example: https://corsproxy.io/
NEXT_PUBLIC_PROXY_URL=""

# API Key for your backend (if required)
NEXT_PUBLIC_API_KEY=""

# ── Firebase (for auth, bookmarks, watch history) ────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your_measurement_id

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
DOMAIN_URL=localhost:3000
